        }
      ]
    },
    "jobId": {
      "allOf": [
        {
          "$ref": "#/components/schemas/JobId"
        },
        {
          "description": "The import job identifier."
        }
      ]
    },
    "jobStatus": {
      "allOf": [
        {
          "$ref": "#/components/schemas/JobStatus"
        },
        {
          "description": "The import job status."
        }
      ]
    },
